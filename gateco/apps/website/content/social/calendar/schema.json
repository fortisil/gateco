{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Social Media Content Calendar",
  "type": "object",
  "required": ["month", "year", "entries"],
  "properties": {
    "month": {
      "type": "integer",
      "minimum": 1,
      "maximum": 12
    },
    "year": {
      "type": "integer",
      "minimum": 2024
    },
    "entries": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/entry"
      }
    }
  },
  "$defs": {
    "entry": {
      "type": "object",
      "required": ["id", "platform", "scheduledDate", "contentType", "pillar", "status"],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z0-9-]+$",
          "description": "Unique identifier (e.g., '2026-03-15-linkedin-001')"
        },
        "platform": {
          "type": "string",
          "enum": ["linkedin", "twitter", "youtube"]
        },
        "scheduledDate": {
          "type": "string",
          "format": "date"
        },
        "scheduledTime": {
          "type": "string",
          "pattern": "^[0-2][0-9]:[0-5][0-9]$",
          "description": "24-hour format (e.g., '09:00')"
        },
        "contentType": {
          "type": "string",
          "enum": [
            "thought-leadership",
            "product-highlight",
            "industry-news",
            "technical-education",
            "engagement",
            "thread",
            "video",
            "announcement"
          ]
        },
        "pillar": {
          "type": "string",
          "enum": ["security-gap", "technical-education", "industry-compliance", "product-company"]
        },
        "status": {
          "type": "string",
          "enum": ["draft", "review", "approved", "scheduled", "published"]
        },
        "content": {
          "type": "object",
          "properties": {
            "text": {
              "type": "string",
              "maxLength": 3000
            },
            "headline": {
              "type": "string",
              "maxLength": 200
            },
            "thread": {
              "type": "array",
              "items": {
                "type": "string",
                "maxLength": 280
              }
            },
            "cta": {
              "type": "string"
            },
            "link": {
              "type": "string",
              "format": "uri"
            },
            "hashtags": {
              "type": "array",
              "items": {
                "type": "string",
                "pattern": "^#[A-Za-z0-9]+"
              },
              "maxItems": 5
            },
            "imageAlt": {
              "type": "string"
            },
            "videoUrl": {
              "type": "string",
              "format": "uri"
            }
          }
        },
        "assets": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "type": {
                "type": "string",
                "enum": ["image", "video", "document"]
              },
              "path": {
                "type": "string"
              },
              "altText": {
                "type": "string"
              }
            }
          }
        },
        "targeting": {
          "type": "object",
          "properties": {
            "persona": {
              "type": "string",
              "enum": ["security-architect", "ai-ml-lead", "platform-engineer", "executive", "general"]
            },
            "industry": {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          }
        },
        "notes": {
          "type": "string"
        },
        "metrics": {
          "type": "object",
          "properties": {
            "impressions": { "type": "integer" },
            "engagements": { "type": "integer" },
            "clicks": { "type": "integer" },
            "shares": { "type": "integer" }
          }
        }
      }
    }
  }
}
